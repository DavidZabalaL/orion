// Plataforma de Control Vehicular — Grupo Kabat
// Modelo de datos — ver SPEC_COMPLETA_Control_Vehicular.md Parte 6

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────── ENUMS ─────────────────────────

enum TipoVehiculo {
  AUTO
  CAMIONETA
  GRUA
  MOTO
  OTRO
}

enum TipoCombustible {
  GASOLINA
  DIESEL
  ELECTRICO
  HIBRIDO
}

enum EstatusUnidad {
  ACTIVO
  CONSIGNACION
  DIRECCION
  BAJA
}

enum MotivoBaja {
  VENTA
  SINIESTRO_TOTAL
  FIN_VIDA_UTIL
  DEVOLUCION
  CONSIGNACION_CERRADA
  OTRO
}

enum PropietarioUnidad {
  SYM
  FIVE_STAR_SYSTEM
  KABAT
  OTRO
}

enum TipoSangre {
  O_POSITIVO
  O_NEGATIVO
  A_POSITIVO
  A_NEGATIVO
  B_POSITIVO
  B_NEGATIVO
  AB_POSITIVO
  AB_NEGATIVO
}

enum EstatusOperador {
  ACTIVO
  SUSPENDIDO
  BAJA
}

enum EstatusDocumental {
  COMPLETO
  INCOMPLETO
  VENCIDO
}

enum TipoDocumentoOperador {
  LICENCIA
  INE
  COMPROBANTE_DOMICILIO
  ANTECEDENTES
  CSF
  EXAMEN_MEDICO
  ANTIDOPING
  CURSO_MANEJO
  CERTIFICACION
}

enum TipoLicencia {
  A
  B
  C
  D
  E
}

enum CategoriaGasto {
  MANTENIMIENTO_PREVENTIVO
  MANTENIMIENTO_CORRECTIVO
  LLANTAS
  REFACCIONES
  CONSUMIBLES
  TENENCIA
  VERIFICACION
  EMPLACAMIENTO
  ESTACIONAMIENTO
  MULTAS
  RENTA_VEHICULOS
  CASETAS
}

enum EstatusGasto {
  PROGRAMADO
  REALIZADO
  PAGADO
  CANCELADO
}

enum FuenteCombustible {
  API
  ARCHIVO
  MANUAL
}

enum ProveedorTag {
  IAVE
  PASE
  TELEVIA
}

enum EstatusSeguro {
  VIGENTE
  POR_VENCER
  VENCIDO
  RENOVADO
}

enum TipoCobertura {
  RC_TERCEROS
  DANOS_MATERIALES
  ROBO_TOTAL
  ROBO_PARCIAL
  GASTOS_MEDICOS
  ASISTENCIA_VIAL
  RC_PERSONAS
  COBERTURA_LEGAL
  PERDIDA_TOTAL
  EXTENSION_RC
  ESPECIAL
}

enum FuenteGPS {
  API
  WEBHOOK
}

enum MotivoAnomaliaGPS {
  VELOCIDAD_IMPOSIBLE
  FUERA_DE_PAIS
  SALTO_DISTANCIA
}

enum TipoGeocerca {
  INMUEBLE
  ZONA_TRABAJO
  RUTA
  PAIS
}

enum CategoriaAuditoria {
  COMBUSTIBLE
  TAG
  MANTENIMIENTO
  OTRO
}

enum TipoDiscrepancia {
  MONTO
  UNIDAD_FALTANTE
  DUPLICADO
  OTRO
}

enum EstatusAuditoria {
  ABIERTA
  RESUELTA
}

enum AccionBitacora {
  CREAR
  EDITAR
  DAR_DE_BAJA
  REACTIVAR
}

enum EstatusProyecto {
  ACTIVO
  CERRADO
}

enum EstatusUsuario {
  ACTIVO
  INVITADO
  DESACTIVADO
}

enum FrecuenciaReporte {
  DIARIO
  SEMANAL
  MENSUAL
}

// ───────────────────────── MÓDULO K — USUARIOS Y ROLES ─────────────────────────

model Rol {
  id        String   @id @default(cuid())
  nombre    String   @unique
  permisos  Json // módulo × acción × proyecto
  usuarios  Usuario[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Usuario {
  id                String            @id @default(cuid())
  nombre            String
  correo            String            @unique
  rolId             String
  rol               Rol               @relation(fields: [rolId], references: [id])
  estatus           EstatusUsuario    @default(INVITADO)
  proyectos         UsuarioProyecto[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  bitacora          BitacoraCambio[]
  checklists        Checklist[]
  documentosVerificados DocumentoOperador[]
  auditorias        Auditoria[]
  reportesProgramados  ReporteProgramado[]
}

model UsuarioProyecto {
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, proyectoId])
}

model Documento {
  id                String   @id @default(cuid())
  entidadRelacionada String
  entidadId         String
  url               String
  tipo              String
  fechaCarga        DateTime @default(now())

  operadoresFoto    Operador[]            @relation("OperadorFoto")
  documentosOperador DocumentoOperador[]
  gastos            GastoVehicular[]
  checklists        Checklist[]
  seguros           Seguro[]
}

// ───────────────────────── MÓDULO H — PROYECTOS ─────────────────────────

model Proyecto {
  id                    String            @id @default(cuid())
  nombre                String
  estadoRepublica       String
  coordinadorId         String?
  fechaInicio           DateTime
  fechaFin              DateTime?
  estatus               EstatusProyecto   @default(ACTIVO)
  presupuestoSemanal     Decimal           @default(0) @db.Decimal(12, 2)
  semanaActualGastado    Decimal           @default(0) @db.Decimal(12, 2)
  modulosActivos        Json
  procesosActivos       Json

  unidades              Unidad[]
  operadores            Operador[]
  usuarios              UsuarioProyecto[]
  gastosTag             Tag[]
  combustible           Combustible[]
  geocercas             Geocerca[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

// ───────────────────────── MÓDULO A/B — UNIDAD ─────────────────────────

model Unidad {
  numeroEconomico      String            @id
  placas               String            @unique
  numeroSerie          String            @unique
  marca                String
  unidadModelo         String
  anio                 Int
  tipoVehiculo         TipoVehiculo
  tipoCombustible      TipoCombustible
  rendimientoPromedio  Decimal?          @db.Decimal(6, 2)
  kmOficial            Int               @default(0)

  proyectoId           String?
  proyecto             Proyecto?         @relation(fields: [proyectoId], references: [id])
  estadoOperacion      String

  estatus              EstatusUnidad     @default(ACTIVO)
  disponibilidad       Boolean           @default(true)
  diasSinOperar        Int               @default(0)

  resguardanteId       String?
  resguardante         Operador?         @relation("ResguardanteActual", fields: [resguardanteId], references: [id])

  propietario          PropietarioUnidad
  origenPlaca          String
  tagIave              String?

  fechaAlta            DateTime          @default(now())
  fechaBaja            DateTime?
  motivoBaja           MotivoBaja?
  comentarioBaja       String?

  asignaciones         AsignacionOperador[]
  resguardos           Resguardo[]
  checklists           Checklist[]
  gastos               GastoVehicular[]
  combustible          Combustible[]
  tags                 Tag[]
  seguros              Seguro[]
  posicionesGps        PosicionGPS[]
  huecosGps            HuecoSenalGPS[]
  mapeoTarjetas        MapeoTarjetaEconomico[]
  auditorias           Auditoria[]

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([proyectoId])
  @@index([estatus])
}

// ───────────────────────── MÓDULO L — OPERADORES ─────────────────────────

model Operador {
  id                  String              @id @default(cuid())
  nombre              String
  curp                String              @unique
  rfc                 String?
  nss                 String?
  tipoSangre          TipoSangre?
  telefono            String?
  contactoEmergencia  String?
  fotoId              String?
  foto                Documento?          @relation("OperadorFoto", fields: [fotoId], references: [id])

  proyectoId          String?
  proyecto            Proyecto?           @relation(fields: [proyectoId], references: [id])

  estatus             EstatusOperador     @default(ACTIVO)
  estatusDocumental   EstatusDocumental   @default(INCOMPLETO)

  documentos          DocumentoOperador[]
  asignaciones        AsignacionOperador[]
  resguardos          Resguardo[]
  unidadesResguardadas Unidad[]           @relation("ResguardanteActual")

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([proyectoId])
}

model DocumentoOperador {
  id                 String                @id @default(cuid())
  operadorId         String
  operador           Operador              @relation(fields: [operadorId], references: [id], onDelete: Cascade)
  tipoDocumento      TipoDocumentoOperador
  numero             String?
  tipoLicencia       TipoLicencia?
  estadoEmisor       String?
  fechaEmision       DateTime
  fechaVencimiento   DateTime?
  archivoId          String
  archivo            Documento             @relation(fields: [archivoId], references: [id])
  verificado         Boolean               @default(false)
  fechaVerificacion  DateTime?
  verificadoPorId    String?
  verificadoPor      Usuario?              @relation(fields: [verificadoPorId], references: [id])

  createdAt          DateTime              @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([operadorId])
  @@index([fechaVencimiento])
}

model AsignacionOperador {
  id               String    @id @default(cuid())
  operadorId       String
  operador         Operador  @relation(fields: [operadorId], references: [id])
  numeroEconomico  String
  unidad           Unidad    @relation(fields: [numeroEconomico], references: [numeroEconomico])
  fechaDesde       DateTime
  fechaHasta       DateTime?
  motivoCambio     String?

  @@index([numeroEconomico])
  @@index([operadorId])
}

model Resguardo {
  id               String    @id @default(cuid())
  numeroEconomico  String
  unidad           Unidad    @relation(fields: [numeroEconomico], references: [numeroEconomico])
  operadorId       String
  operador         Operador  @relation(fields: [operadorId], references: [id])
  fechaDesde       DateTime
  fechaHasta       DateTime?
  motivoCambio     String?

  @@index([numeroEconomico])
  @@index([operadorId])
}

// ───────────────────────── MÓDULO A.1 — CHECKLIST ─────────────────────────

model Checklist {
  id                String    @id @default(cuid())
  numeroEconomico   String
  unidad            Unidad    @relation(fields: [numeroEconomico], references: [numeroEconomico])
  fecha             DateTime
  odometro          Int
  puntosInspeccion  Json
  evidenciaId       String?
  evidencia         Documento? @relation(fields: [evidenciaId], references: [id])
  capturadoPorId    String
  capturadoPor      Usuario   @relation(fields: [capturadoPorId], references: [id])

  createdAt         DateTime  @default(now())

  @@index([numeroEconomico, fecha])
}

// ───────────────────────── MÓDULO C — GASTOS VEHICULARES ─────────────────────────

model GastoVehicular {
  id                 String          @id @default(cuid())
  numeroEconomico    String
  unidad             Unidad          @relation(fields: [numeroEconomico], references: [numeroEconomico])
  categoria          CategoriaGasto
  descripcion        String?
  fecha              DateTime
  costo              Decimal         @db.Decimal(12, 2)
  kmAlMomento        Int?
  proveedor          String?
  servicio           String?
  empresa            String?

  sc                 String?
  odc                String?
  entradaSap         String?
  fechaRequisicion   DateTime?
  fechaOdc           DateTime?
  fechaFactura       DateTime?
  fechaCxp           DateTime?
  fechaPago          DateTime?

  evidenciaId        String?
  evidencia          Documento?      @relation(fields: [evidenciaId], references: [id])
  estatus            EstatusGasto    @default(PROGRAMADO)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([numeroEconomico])
  @@index([categoria])
}

// ───────────────────────── MÓDULO D — COMBUSTIBLE ─────────────────────────

model ConfiguracionProveedorCombustible {
  id             String        @id @default(cuid())
  nombre         String        @unique
  mapeoColumnas  Json
  formatoFecha   String
  combustible    Combustible[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Combustible {
  id                      String                              @id @default(cuid())
  numeroEconomico         String
  unidad                  Unidad                              @relation(fields: [numeroEconomico], references: [numeroEconomico])
  fecha                   DateTime
  litros                  Decimal                             @db.Decimal(10, 2)
  costo                   Decimal                             @db.Decimal(12, 2)
  kmActual                Int
  estacion                String?
  rfcEstacion             String?
  proyectoReportanteId    String?
  proyectoReportante      Proyecto?                           @relation(fields: [proyectoReportanteId], references: [id])
  fuente                  FuenteCombustible                   @default(MANUAL)
  proveedorConfigId       String?
  proveedorConfig         ConfiguracionProveedorCombustible?  @relation(fields: [proveedorConfigId], references: [id])
  rendimientoCalculado    Decimal?                            @db.Decimal(6, 2)

  createdAt               DateTime                            @default(now())

  @@index([numeroEconomico, fecha])
}

model MapeoTarjetaEconomico {
  numeroTarjeta    String    @id
  placaAsociada    String?
  numeroEconomico  String
  unidad           Unidad    @relation(fields: [numeroEconomico], references: [numeroEconomico])
  proveedor        String
  vigenciaDesde    DateTime
  vigenciaHasta    DateTime?

  @@index([numeroEconomico])
}

// ───────────────────────── MÓDULO E — TAG / PEAJES ─────────────────────────

model Tag {
  id                    String        @id @default(cuid())
  numeroEconomico       String?
  unidad                Unidad?       @relation(fields: [numeroEconomico], references: [numeroEconomico])
  fecha                 DateTime
  monto                 Decimal       @db.Decimal(10, 2)
  caseta                String?
  proveedorTag          ProveedorTag
  tarjetaIdmx           String?
  proyectoReportanteId  String?
  proyectoReportante    Proyecto?     @relation(fields: [proyectoReportanteId], references: [id])
  conciliado            Boolean       @default(false)

  createdAt             DateTime      @default(now())

  @@index([numeroEconomico, fecha])
}

// ───────────────────────── MÓDULO F — SEGUROS ─────────────────────────

model Seguro {
  id               String            @id @default(cuid())
  numeroEconomico  String
  unidad           Unidad            @relation(fields: [numeroEconomico], references: [numeroEconomico])
  aseguradora      String
  numeroPoliza     String
  fechaInicio      DateTime
  fechaVencimiento DateTime
  costo            Decimal           @db.Decimal(12, 2)
  documentoId      String?
  documento        Documento?        @relation(fields: [documentoId], references: [id])
  estatus          EstatusSeguro     @default(VIGENTE)

  coberturas       CoberturaSeguro[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([numeroEconomico])
  @@index([fechaVencimiento])
}

model CoberturaSeguro {
  id                   String        @id @default(cuid())
  seguroId             String
  seguro               Seguro        @relation(fields: [seguroId], references: [id], onDelete: Cascade)
  tipoCobertura        TipoCobertura
  sumaAsegurada        Decimal       @db.Decimal(12, 2)
  deducible            Decimal       @db.Decimal(12, 2)
  condicionesEspeciales String?

  @@index([seguroId])
}

// ───────────────────────── MÓDULO G / G.1 — GEOLOCALIZACIÓN ─────────────────────────

model PosicionGPS {
  id               String              @id @default(cuid())
  numeroEconomico  String
  unidad           Unidad              @relation(fields: [numeroEconomico], references: [numeroEconomico])
  lat              Decimal             @db.Decimal(9, 6)
  lng              Decimal             @db.Decimal(9, 6)
  velocidad        Decimal?            @db.Decimal(6, 2)
  timestamp        DateTime
  fuente           FuenteGPS
  kmReportado      Int?
  kmValidado       Int?
  esAnomalo        Boolean             @default(false)
  motivoAnomalia   MotivoAnomaliaGPS?

  @@index([numeroEconomico, timestamp])
}

model HuecoSenalGPS {
  id                    String    @id @default(cuid())
  numeroEconomico       String
  unidad                Unidad    @relation(fields: [numeroEconomico], references: [numeroEconomico])
  ultimaPosicionLat     Decimal   @db.Decimal(9, 6)
  ultimaPosicionLng     Decimal   @db.Decimal(9, 6)
  timestampInicio       DateTime
  timestampFin          DateTime?
  duracionMinutos       Int?
  primeraPosicionLat    Decimal?  @db.Decimal(9, 6)
  primeraPosicionLng    Decimal?  @db.Decimal(9, 6)
  distanciaSaltoKm      Decimal?  @db.Decimal(8, 2)
  patronRecurrente      Boolean   @default(false)

  @@index([numeroEconomico])
}

model Geocerca {
  id           String        @id @default(cuid())
  nombre       String
  tipo         TipoGeocerca
  poligono     Json
  proyectoId   String?
  proyecto     Proyecto?     @relation(fields: [proyectoId], references: [id])
  horaLimite   String?
  activa       Boolean       @default(true)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ───────────────────────── MÓDULO I — AUDITORÍA ─────────────────────────

model Auditoria {
  id                 String              @id @default(cuid())
  numeroEconomico    String
  unidad             Unidad              @relation(fields: [numeroEconomico], references: [numeroEconomico])
  fechaRevision      DateTime
  revisorId          String
  revisor            Usuario             @relation(fields: [revisorId], references: [id])
  categoriaGasto     CategoriaAuditoria
  montoPptto         Decimal             @db.Decimal(12, 2)
  montoReal          Decimal             @db.Decimal(12, 2)
  montoCv            Decimal             @db.Decimal(12, 2)
  diferencia         Decimal             @db.Decimal(12, 2)
  tipoDiscrepancia   TipoDiscrepancia?
  resolucion         String?
  estatus            EstatusAuditoria    @default(ABIERTA)

  createdAt          DateTime            @default(now())

  @@index([numeroEconomico, fechaRevision])
}

// ───────────────────────── BITÁCORA ─────────────────────────

model BitacoraCambio {
  id                String          @id @default(cuid())
  entidad           String
  entidadId         String
  usuarioId         String
  usuario           Usuario         @relation(fields: [usuarioId], references: [id])
  timestamp         DateTime        @default(now())
  accion            AccionBitacora
  valoresAnteriores Json?
  valoresNuevos     Json?

  @@index([entidad, entidadId])
}

// ───────────────────────── MÓDULO J — REPORTES ─────────────────────────

model ReporteProgramado {
  id            String            @id @default(cuid())
  nombre        String
  tipo          String
  camposJson    Json
  filtrosJson   Json
  destinatarios Json
  hora          String
  frecuencia    FrecuenciaReporte
  activo        Boolean           @default(true)
  creadoPorId   String
  creadoPor     Usuario           @relation(fields: [creadoPorId], references: [id])

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}
